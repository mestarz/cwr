    "@vitejs/plugin-react": "6.0.2",
    "lucide-react": "1.17.0",
    "mermaid": "11.15.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "vite": "8.0.16"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
